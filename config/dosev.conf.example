[server]
listen_ip = 0.0.0.0
listen_port = 53

[resolver]
upstream_dns = 1.1.1.1:53
protocol = udp
verbose = false
disable_ipv6 = false
dns_max_payload = 4096  # maximum EDNS0 UDP payload advertised and accepted

dns_enable_dot = false
# dns_dot_port = 853
# dns_dot_cert_file = /path/to/cert.pem
# dns_dot_key_file = /path/to/key.pem

dns_enable_doh = false
# dns_doh_port = 443
# dns_doh_cert_file = /path/to/cert.pem
# dns_doh_key_file = /path/to/key.pem
# dns_doh_path = /dns-query

[cache]
ttl = 300
max_size = 1024
negative_ttl = 5

[timeouts]
udp = 2.0
tcp = 5.0
doh = 5.0

[advanced]
retries = 2
rate_limit_rps = 0.0
rate_limit_burst = 0.0
optimistic_cache_enabled = false
optimistic_stale_max_age = 86400
optimistic_stale_response_ttl = 30
pool_max_size = 5
pool_idle_timeout = 60.0
doh_version = auto
doh_auto_cache_ttl = 3600

[security]
# Enable DNSSEC validation (uses bundled root key by default)
dnssec_enabled = false

# Automatically fetch and update root trust anchor from IANA (RFC 5011 style)
auto_update_trust_anchor = true

# Optional: path to a file with custom trust anchors (DNSKEY/DS records)
# If not set, the built-in root key is used.
trust_anchors_file =

# Certificate pinning (format: hostname=sha256_fingerprint, ...)
pinned_certs =

# Rebinding protection
rebind_protection = false
rebind_action = strip

# Privilege dropping (Linux/Unix only)
dns_privilege_drop_user =
dns_privilege_drop_group =
dns_chroot_dir =

[logging]
enabled = false
log_dir = /var/log/dosev
retention_days = 7
log_prefix = dns-log

[metrics]
enabled = false
port = 8000
uvloop_enable = false

[bootstrap]
servers = 1.1.1.1:53,8.8.8.8:53
timeout = 2.0
retries = 2

[upstreams]
# servers = primary,secondary
# [upstreams.primary]
# address = 1.1.1.1
# protocol = udp
# port = 5353
# hostname = one.one.one.one
# [upstreams.secondary]
# address = 8.8.8.8
# protocol = tls
# port = 853
# hostname = dns.google

[blocklists]
enabled = false
urls = https://raw.githubusercontent.com/StevenBlack/hosts/master/hosts
interval_seconds = 86400
action = NXDOMAIN
local_blocklist_dir = blocklists
reload_on_change = true